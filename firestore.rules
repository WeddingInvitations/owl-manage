rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /employee_payments/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner();
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
        getUserData().data.role : 'OWNER';
    }

    function isOwner() {
      return request.auth != null && role() == 'OWNER';
    }

    function isCoach() {
      return request.auth != null && role() == 'COACH';
    }

    function isReception() {
      return request.auth != null && role() == 'RECEPTION';
    }

    function isSelf(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isOwner() || (isSelf(userId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'mustChangePassword',
          'firstName',
          'lastName',
          'updatedAt',
        ]));
      allow delete: if isOwner();
    }

    match /payments/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception();
    }

    match /expenses/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner();
    }

    match /checkins/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception() || isCoach();
    }

    match /trainings/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isCoach();
    }

    match /athletes/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception();
    }

    match /athlete_months/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception();
    }

    match /athletes_acrobacias/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception();
    }

    match /athlete_acrobacias_months/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception();
    }

    match /athletes_halterofilia/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception();
    }

    match /athlete_halterofilia_months/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception();
    }

    match /athletes_telas/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception() || isCoach();
    }

    match /athlete_telas_months/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception() || isCoach();
    }

    match /athletes_singleclasses/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception() || isCoach();
    }

    match /athlete_singleclasses_months/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception() || isCoach();
    }

    match /vacations/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner() || isReception();
    }

    match /teachers/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner();
    }

    match /classes/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner();
    }

    match /class_assignments/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isOwner();
    }

    // Permitir a cualquier usuario autenticado leer y escribir ventas en la colección sales
    match /sales/{docId} {
      allow read, write: if request.auth != null;
    }

    // Permitir a cualquier usuario autenticado leer y escribir pedidos en la colección orders
    match /orders/{docId} {
      allow read, write: if request.auth != null;
    }

  }
}
